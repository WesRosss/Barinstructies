# BunnyCDN Storage Zone Configuration
# Vul deze in met je eigen credentials (niet committen!)
BUNNYCDN_ACCESS_KEY=your_bunnycdn_access_key
BUNNYCDN_PASSWORD=your_bunnycdn_password
BUNNYCDN_STORAGE_ZONE=instructievideos
BUNNYCDN_REGION_ENDPOINT=https://storage.bunnycdn.com

# CDN Configuration
CDN_BASE_URL=https://cdn.barinstructies.nl
USE_CDN=true

# Thumbnail Configuration
# Set GENERATE_THUMBNAILS=true to enable thumbnail generation from local videos
GENERATE_THUMBNAILS=true
# Set HAS_LOCAL_VIDEOS=true only if you have local video files for thumbnail generation (test environment)
HAS_LOCAL_VIDEOS=false
THUMBNAIL_WIDTH=320
THUMBNAIL_HEIGHT=180

# Server Configuration
PORT=3210
NODE_ENV=production
