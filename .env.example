# Bar Instructies Configuration

# Server Configuration
PORT=3210
NODE_ENV=production

# CDN Configuration
CDN_BASE_URL=https://cdn.barinstructies.nl
USE_CDN=true
GENERATE_THUMBNAILS=true
THUMBNAIL_WIDTH=320
THUMBNAIL_HEIGHT=180

# BunnyCDN Configuration (for automatic uploads)
BUNNYCDN_ACCESS_KEY=your-bunnycdn-access-key
BUNNYCDN_PASSWORD=your-bunnycdn-password
BUNNYCDN_STORAGE_ZONE=instructievideos
BUNNYCDN_REGION_ENDPOINT=https://storage.bunnycdn.com

# JWT Authentication
JWT_SECRET=your-very-secure-jwt-secret-change-this-in-production
JWT_EXPIRES_IN=24h

# Upload Configuration
MAX_FILE_SIZE=524288000  # 500MB

# Default Admin User (will be created on first run)
# Username: admin
# Password: admin123
# Note: Change this immediately after first login!
